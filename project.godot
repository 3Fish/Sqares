; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but the file format allows reading/writing it manually.

config_version=5

[application]

config/name="Sqares"
config/description="A 2D Rogue-Like Arena Battle Shooter. Free, open-source, and mod-friendly."
config/version="0.1.0"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/core/game_manager.gd"
ModLoader="*res://scripts/mods/mod_loader.gd"
StatRegistry="*res://scripts/mods/stat_registry.gd"
CardRegistry="*res://scripts/mods/card_registry.gd"
LevelRegistry="*res://scripts/mods/level_registry.gd"
GameModeRegistry="*res://scripts/mods/game_mode_registry.gd"
UIManager="*res://scripts/mods/ui_manager.gd"
PlayerActionRegistry="*res://scripts/mods/player_action_registry.gd"
NetworkManager="*res://scripts/multiplayer/network_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

